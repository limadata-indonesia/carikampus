generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ──────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  phone         String?
  role          UserRole  @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  student       Student?
  testSessions  TestSession[]
  testPurchases TestPurchase[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── STUDENT ───────────────────────────────────────────
model Student {
  id               String   @id @default(cuid())
  userId           String   @unique
  nisn             String?  @unique
  schoolName       String?
  schoolCity       String?
  gradeYear        Int?
  interests        String[] // RIASEC categories
  programLevel     String?  // S1, D3, D4
  locationPref     String[] // provinces
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedUniversities SavedUniversity[]
  applications     Application[]

  @@map("students")
}

model SavedUniversity {
  id           String   @id @default(cuid())
  studentId    String
  universityId String
  createdAt    DateTime @default(now())

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([studentId, universityId])
  @@map("saved_universities")
}

// ─── UNIVERSITY ────────────────────────────────────────
model University {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  logo             String?
  bannerImage      String?
  type             UniversityType    @default(PRIVATE)
  accreditation    String?
  province         String
  city             String
  address          String?
  phone            String?
  email            String?
  website          String?
  description      String?
  founded          Int?
  totalStudents    Int?
  totalFaculties   Int?
  qsRanking        Int?
  registrationFee  Int               @default(0)
  intakeMonth      String?
  intakeYear       Int?
  deadline         DateTime?
  status           UniversityStatus  @default(PENDING)
  approvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  adminId          String?
  admin            UniversityAdmin?

  faculties        Faculty[]
  facilities       Facility[]
  dormitories      Dormitory[]
  reviews          Review[]
  applications     Application[]
  savedBy          SavedUniversity[]
  blogPosts        BlogPost[]
  seoSettings      UniversitySEO?

  @@map("universities")
}

model UniversityAdmin {
  id           String   @id @default(cuid())
  universityId String   @unique
  email        String   @unique
  name         String
  phone        String?
  emailDomain  String?
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("university_admins")
}

model Faculty {
  id           String    @id @default(cuid())
  universityId String
  name         String
  createdAt    DateTime  @default(now())

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  programs     Program[]

  @@map("faculties")
}

model Program {
  id             String   @id @default(cuid())
  facultyId      String
  name           String
  degree         String   // S1, S2, S3, D3, D4
  accreditation  String?
  duration       Int?     // in years
  createdAt      DateTime @default(now())

  faculty        Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  applications   Application[]

  @@map("programs")
}

model Facility {
  id           String   @id @default(cuid())
  universityId String
  name         String
  category     String   // ACADEMIC, SPORTS, GENERAL
  icon         String?

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("facilities")
}

model Dormitory {
  id           String   @id @default(cuid())
  universityId String
  name         String
  type         String   // PUTRA, PUTRI, MIXED, SUITE
  pricePerMonth Int
  capacity     Int?
  amenities    String[]

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("dormitories")
}

model Review {
  id           String   @id @default(cuid())
  universityId String
  authorName   String
  program      String?
  graduationYear Int?
  rating       Int      // 1-5
  content      String
  createdAt    DateTime @default(now())

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model UniversitySEO {
  id             String   @id @default(cuid())
  universityId   String   @unique
  metaTitle      String?
  metaDesc       String?
  focusKeyword   String?
  geoDescription String?
  ogImage        String?
  schemaJson     String?
  updatedAt      DateTime @updatedAt

  university     University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@map("university_seo")
}

model BlogPost {
  id           String      @id @default(cuid())
  universityId String
  title        String
  slug         String
  content      String
  excerpt      String?
  coverImage   String?
  published    Boolean     @default(false)
  publishedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  metaTitle    String?
  metaDesc     String?

  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, slug])
  @@map("blog_posts")
}

// ─── PLATFORM ARTICLES ─────────────────────────────────
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  category    String    // Tips Karier, Universitas, Tes Minat, SNBT, Biaya Kuliah, Karier
  emoji       String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  readTime    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("articles")
}

// ─── APPLICATION ───────────────────────────────────────
model Application {
  id           String            @id @default(cuid())
  studentId    String
  universityId String
  programId    String?
  status       ApplicationStatus @default(DRAFT)
  paymentId    String?
  paidAt       DateTime?
  submittedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  university   University @relation(fields: [universityId], references: [id])
  program      Program?   @relation(fields: [programId], references: [id])

  @@map("applications")
}

// ─── APTITUDE TEST ─────────────────────────────────────
model TestSession {
  id           String      @id @default(cuid())
  userId       String
  resumeToken  String      @unique @default(cuid())
  section      Int         @default(0)
  answers      Json        @default("{}")
  status       TestStatus  @default(IN_PROGRESS)
  startedAt    DateTime    @default(now())
  completedAt  DateTime?
  lastActiveAt DateTime    @default(now())

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  result       TestResult?

  @@map("test_sessions")
}

model TestResult {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  riasecR       Int      @default(0)
  riasecI       Int      @default(0)
  riasecA       Int      @default(0)
  riasecS       Int      @default(0)
  riasecE       Int      @default(0)
  riasecC       Int      @default(0)
  topProfile    String?
  personalityType String?
  learningStyle String?
  cognitiveScore Int?
  recommendations Json   @default("[]")
  createdAt     DateTime @default(now())

  session       TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("test_results")
}

model TestPurchase {
  id              String          @id @default(cuid())
  userId          String
  package         TestPackage
  amount          Int
  status          PaymentStatus   @default(PENDING)
  midtransOrderId String?         @unique
  midtransToken   String?
  paidAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGrant     TestAccessGrant?

  @@map("test_purchases")
}

model TestAccessGrant {
  id           String       @id @default(cuid())
  userId       String
  source       AccessSource
  purchaseId   String?      @unique
  accessCode   String?
  active       Boolean      @default(true)
  expiresAt    DateTime?
  createdAt    DateTime     @default(now())

  purchase     TestPurchase? @relation(fields: [purchaseId], references: [id])

  @@map("test_access_grants")
}

// ─── SCHOOL ACCESS CODES ───────────────────────────────
model SchoolAccessBatch {
  id         String   @id @default(cuid())
  schoolName String
  code       String   @unique
  quota      Int
  used       Int      @default(0)
  pic        String?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  codes      SchoolAccessCode[]

  @@map("school_access_batches")
}

model SchoolAccessCode {
  id        String   @id @default(cuid())
  batchId   String
  code      String   @unique
  studentName String?
  nisn      String?
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  batch     SchoolAccessBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("school_access_codes")
}

// ─── ENUMS ─────────────────────────────────────────────
enum UserRole {
  STUDENT
  UNIVERSITY_ADMIN
  SCHOOL_ADMIN
  PLATFORM_ADMIN
}

enum UniversityType {
  NEGERI
  PRIVATE
  KEAGAMAAN
  KEDINASAN
}

enum UniversityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PAID
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum TestStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum TestPackage {
  BASIC
  FULL
  FAMILY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum AccessSource {
  PURCHASE
  SCHOOL_CODE
  VOUCHER
  MANUAL_GRANT
}
